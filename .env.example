# Relay backend environment (copy to backend/.env for local dev)

NODE_ENV=development
PORT=3000

# Postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=relay

# Auth (Google OAuth + JWT) - reused from the backoffice pattern
JWT_SECRET=change-me
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
ALLOWED_EMAIL_DOMAIN=apono.io

# GitHub - LOCAL Phase 1 uses a read-only fine-grained PAT
GITHUB_AUTH_MODE=pat
GITHUB_PAT=

# GitHub - DEPLOYED path uses the GitHub App (unused locally)
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# Ingestion scope (Relay is multi-repo)
GITHUB_REPOS=apono-io/apono-mono,apono-io/Relay
BACKFILL_QUARTERS=3

# Metric defaults
DEFAULT_REVIEW_SLA_MINUTES=120
GAP_FILL_INTERVAL_MINUTES=10
